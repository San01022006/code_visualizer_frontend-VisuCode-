<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- Allow HTTP for Android Emulator (10.0.2.2) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Allow HTTP for Genymotion emulator (optional) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>

    <!-- Allow HTTP for your PC's local server (real device access) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">0.0.0.0</domain>
    </domain-config>

    <!-- Keep cleartext blocked for everything else -->
    <base-config cleartextTrafficPermitted="false" />

</network-security-config>
